# ── REQUIRED (at least one) ──────────────────────────────
GEMINI_API_KEY_1=get_free_key_at_aistudio.google.com
# GEMINI_API_KEY_2=second_google_account_key
# GEMINI_API_KEY_3=third_google_account_key

# ── GROQ (free, fast, recommended) ───────────────────────
# Get free key at: console.groq.com
# GROQ_API_KEY_1=your_groq_key
# GROQ_API_KEY_2=second_groq_key

# ── OPENROUTER (free models available) ───────────────────
# OPENROUTER_API_KEY_1=your_openrouter_key

# ── GOOGLE SHEETS (optional) ─────────────────────────────
GOOGLE_SHEETS_ID=your_sheet_id_from_url

# ── HOW MANY KEYS SHOULD YOU ADD? ────────────────────────
# 1 Gemini key: scores ~15 jobs/min sequentially
# 1 Gemini + 1 Groq: scores ~30 jobs/min with 2 workers
# 2 Gemini + 2 Groq + 1 OpenRouter: scores ~60 jobs/min with 5 workers
# More keys = faster scoring, higher daily limits